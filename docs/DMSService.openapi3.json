            "explode": false,
            "schema": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "objectId",
                  "name",
                  "type",
                  "mimeType",
                  "size",
                  "createdAt",
                  "createdBy"
                ]
              }
            }
