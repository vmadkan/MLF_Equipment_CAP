            "in": "query",
            "explode": false,
            "schema": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "objectId",
                  "objectId desc",
                  "name",
                  "name desc",
                  "type",
                  "type desc",
                  "mimeType",
                  "mimeType desc",
                  "size",
                  "size desc",
                  "createdAt",
                  "createdAt desc",
                  "createdBy",
                  "createdBy desc"
