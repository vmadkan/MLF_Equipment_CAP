{
  "version": "1.38.0",
  "tasks": [
    {
      "label": "kill-cds-processes",
      "type": "shell",
      "command": "pids=$(ps aux | grep -vE 'grep|bash' | grep 'cds.js' | awk '{print $2}'); if [ -n \"$pids\" ]; then kill $pids; fi",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "npm-install",
      "type": "process",
      "command": "npm",
      "args": [
        "install"
      ],
      "dependsOn": [
        "kill-cds-processes"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "BuildMDK",
      "type": "shell",
      "command": "if npm list @sap/mdk-tools --depth=0 > /dev/null 2>&1; then npx mdk build --target module --ui5 --recursive;fi",
      "dependsOn": [
        "npm-install"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "PreLaunchTask for Run MLF_Equipment_MVP",
      "type": "process",
      "command": "npx",
      "args": [
        "dev-cap-tools",
        "gen-entrypoint"
      ],
      "dependsOn": [
        "BuildMDK"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "type": "dpt.ptdeploy",
      "label": "Deploy MLF_Equipment_MVP",
      "taskType": "Deploy"
    },
    {
      "type": "dpt.ptdeploy",
      "label": "Enable Discovery and Deploy MLF_Equipment_MVP",
      "taskType": "Deploy",
      "enableDiscovery": "true"
    },
    {
      "type": "build.mta",
      "label": "Build MTA: MLF_Equipment_MVP - PT",
      "taskType": "Build",
      "projectPath": "/home/user/projects/CAP_MLF_Equipment",
      "extensions": [],
      "ui5theme": "sap_horizon",
      "vendorDependency": false,
      "buildCodeServicePlan": true,
      "subdomain": "deloittegenaihubcf-ydd7grnx",
      "ui5version": "1.144.1"
    },
    {
      "type": "deploy.mta.cf",
      "label": "Deploy MTA to Cloud Foundry: MLF_Equipment_MVP - PT",
      "taskType": "Deploy",
      "mtarPath": "/home/user/projects/MLF_Equipment_CAP/mta_archives/*.mtar",
      "cfTarget": "",
      "cfEndpoint": "",
      "cfOrg": "",
      "cfSpace": "",
      "extensions": [],
      "dependsOn": [
        "Build MTA: MLF_Equipment_MVP - PT"
      ]
    },
    {
      "type": "build.mta",
      "label": "Build MTA: MLF_Equipment_MVP - PT (2)",
      "taskType": "Build",
      "projectPath": "/home/user/projects/MLF_Equipment_CAP",
      "extensions": [],
      "ui5theme": "sap_horizon",
      "vendorDependency": false,
      "buildCodeServicePlan": true,
      "subdomain": "",
      "ui5version": "1.144.1"
    },
    {
      "type": "build.mta",
      "label": "Build MTA: mlf-equipment-mvp - PT",
      "taskType": "Build",
      "projectPath": "/home/user/projects/MLF_Equipment_CAP",
      "extensions": [],
      "ui5theme": "sap_horizon",
      "vendorDependency": false,
      "buildCodeServicePlan": true,
      "subdomain": "",
      "ui5version": "1.144.1"
    },
    {
      "type": "build.mta",
      "label": "Build MTA: mlf-equipment-mvp - PT (2)",
      "taskType": "Build",
      "projectPath": "/home/user/projects/MLF_Equipment_CAP",
      "extensions": [],
      "ui5theme": "sap_horizon",
